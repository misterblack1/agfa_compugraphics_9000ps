;  VERA and NVRAM includes
;  Must appear before EhBASIC (ehbasic68k.inc ends with END).
;******************************************************************************

        INCLUDE "include/nvram_config.inc"
        INCLUDE "include/vera_init.inc"
        INCLUDE "include/vera_text.inc"
        INCLUDE "include/vera_cursor.inc"
        INCLUDE "include/via_timer.inc"


;******************************************************************************
;  EhBASIC (Agfa hardware wrapper + core engine)
;  Included LAST - ehbasic68k.inc ends with END which stops all assembly.
;******************************************************************************

        ORG     $001800
        INCLUDE "agfa-basic.m68"
