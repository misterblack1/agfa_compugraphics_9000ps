;******************************************************************************
;  EXTENDED COMMANDS  - must appear BEFORE the EhBASIC include because
;  ehbasic68k.inc ends with an END directive that stops all assembly.
;  Binary output places each ORG section at the correct ROM offset regardless
;  of source order.  EhBASIC occupies $1500-$49F1; this section starts at $5000.
;******************************************************************************

        ORG     $005000

;==============================================================================
;  BURNIN_TEST -- continuous RAM burn-in, any key to stop
;
;  5 patterns: AA 55 00 FF address-as-data. Loops until keypress.
;  Output: Pass NNNNN: AA....... 55....... 00....... FF....... AD....... ok
;  One dot per 512KB verified. Errors printed inline (capped at 4 per pattern).
;
;  D4 = per-pattern error count
;  D5 = current pattern ($DEADBEEF = address-as-data sentinel)
;  D6 = pass counter
;  D7 = total error count
;  A3 = pattern table pointer
;  A4 = next dot-threshold address
;==============================================================================
BURNIN_TEST:
        MOVEM.L D0-D7/A0-A6,-(SP)

        LEA     STR_BI_HDR,A0
        BSR     PRINTSTR

        CLR.L   D7                       ; total error count
        MOVEQ   #0,D6                    ; pass counter

;---------- outer pass loop ---------------------------------------------------
BI_PASS_LOOP:
        ADDQ.L  #1,D6
        MOVE.L  D7,-(SP)                 ; snapshot D7 for per-pass ok/err display

        LEA     STR_BI_PASS,A0
        BSR     PRINTSTR
        MOVE.L  D6,D0
        BSR     BI_PRINT_DEC
        LEA     STR_BI_COLON,A0
        BSR     PRINTSTR

        LEA     BI_PATTERNS,A3

;---------- inner pattern loop ------------------------------------------------
BI_PAT_LOOP:
        MOVE.L  (A3)+,D5                 ; load next pattern
        CMPI.L  #$7FFFFFFF,D5            ; end-of-table?
        BEQ.W   BI_PASS_DONE

        CLR.L   D4                       ; per-pattern error count

        ; print 2-char pattern label: high byte as hex, or "AD" for addr-as-data
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        CMPI.L  #$DEADBEEF,D5
        BNE.S   .bi_hexlbl
        MOVE.B  #'A',D0
        BSR     PUTCHAR
        MOVE.B  #'D',D0
        BSR     PUTCHAR
        BRA.S   .bi_write
.bi_hexlbl:
        MOVE.L  D5,D0
        SWAP    D0                       ; high word -> low word
        LSR.W   #8,D0                    ; high byte of pattern -> D0.B
        BSR     PRINT_HEX2

        ;--- write phase (no per-word keycheck) ---
.bi_write:
        MOVEA.L #RAM_TEST_START,A0
        MOVEA.L #RAM_TEST_END,A1
BI_WR:
        CMPI.L  #$DEADBEEF,D5
        BNE.S   .wconst
        MOVE.L  A0,(A0)+
        BRA.S   .wchk
.wconst:
        MOVE.L  D5,(A0)+
.wchk:
        CMPA.L  A1,A0
        BLT.S   BI_WR

        ;--- verify phase (dot + keycheck every 512KB) ---
        MOVEA.L #RAM_TEST_START,A0
        MOVEA.L #RAM_TEST_START+$80000,A4
BI_VFY:
        CMPA.L  A4,A0
        BLT.S   .vfetch
        ADDA.L  #$80000,A4               ; advance dot threshold
        MOVE.B  #'.',D0
        BSR     PUTCHAR
        BTST    #0,SCC_A_CTRL            ; Rx char ready?
        BEQ.S   .vfetch
        MOVE.B  SCC_A_DATA,D0            ; drain char
        MOVE.L  (SP)+,D0                 ; discard pass snapshot
        BRA     BI_STOPPED
.vfetch:
        MOVE.L  (A0)+,D3                 ; read value
        CMPI.L  #$DEADBEEF,D5
        BNE.S   .vconst
        MOVE.L  A0,D2
        SUBQ.L  #4,D2                    ; expected = this longword's address
        BRA.S   .vcmp
.vconst:
        MOVE.L  D5,D2                    ; expected = pattern
.vcmp:
        CMP.L   D3,D2
        BEQ.S   .vnext
        CMPI.L  #4,D4                    ; error cap: max 4 per pattern
        BGE.S   .vnext
        MOVEM.L D4/D5/A0/A1/A3,-(SP)    ; preserve loop state
        MOVEA.L A0,A2
        SUBA.L  #4,A2                    ; A2 = failing address
        MOVE.L  D3,D4                    ; D4 = actual (RT_ERR convention)
        MOVE.L  D2,D5                    ; D5 = expected (RT_ERR convention)
        BSR     RT_ERR
        MOVEM.L (SP)+,D4/D5/A0/A1/A3    ; restore loop state
        ADDQ.L  #1,D4                    ; per-pattern error count
        ADDQ.L  #1,D7                    ; total error count
.vnext:
        CMPA.L  A1,A0
        BLT.W   BI_VFY
        BRA     BI_PAT_LOOP

;---------- end-of-pass -------------------------------------------------------
BI_PASS_DONE:
        MOVE.L  (SP)+,D0                 ; pop pass snapshot
        CMP.L   D7,D0                    ; any new errors this pass?
        BEQ.S   .biok
        LEA     STR_BI_ERR,A0
        BSR     PRINTSTR
        BRA.S   .biscan
.biok:
        LEA     STR_BI_OK,A0
        BSR     PRINTSTR
.biscan:
        BRA     BI_PASS_LOOP

;---------- stopped by keypress -----------------------------------------------
BI_STOPPED:
        BSR     PRINT_CRLF
        LEA     STR_BI_STOP,A0
        BSR     PRINTSTR
        MOVE.L  D6,D0
        BSR     BI_PRINT_DEC
        LEA     STR_BI_STOP2,A0
        BSR     PRINTSTR
        MOVE.L  D7,D0
        BSR     BI_PRINT_DEC
        LEA     STR_BI_STOP3,A0
        BSR     PRINTSTR

        MOVEM.L (SP)+,D0-D7/A0-A6
        RTS


;------------------------------------------------------------------------------
; BI_PRINT_DEC -- print D0.l as unsigned decimal (no leading zeros, up to 10 digits)
;------------------------------------------------------------------------------
BI_PRINT_DEC:
        MOVEM.L D0-D3/A1,-(SP)
        SUBA.W  #12,SP                   ; 12-byte digit buffer (max 10 digits)
        LEA     12(SP),A1                ; point to TOP of buffer; -(A1) stores within it
        MOVEQ   #0,D2                    ; digit count
        MOVEQ   #0,D3
.bpd_lp:
        DIVU.L  #10,D3:D0                ; D0=quotient D3=remainder
        ADDI.B  #'0',D3
        MOVE.B  D3,-(A1)                 ; push digit
        ADDQ.L  #1,D2
        MOVEQ   #0,D3
        TST.L   D0
        BNE.S   .bpd_lp
.bpd_print:
        MOVE.B  (A1)+,D0
        BSR     PUTCHAR
        SUBQ.L  #1,D2
        BNE.S   .bpd_print
        ADDA.W  #12,SP
        MOVEM.L (SP)+,D0-D3/A1
        RTS


;----------------------------------------------------------------------
; Burn-in data
;----------------------------------------------------------------------
        EVEN
BI_PATTERNS:
        DC.L    $FFFFFFFF
        DC.L    $AAAAAAAA
        DC.L    $55555555
        DC.L    $00000000               ; last pass leaves RAM blank
        DC.L    $7FFFFFFF               ; end-of-table marker

STR_BI_HDR:
        DC.B    $0D,$0A,"RAM burn-in $02008000-$023EFFFF. Any key to stop.",$0D,$0A,0
STR_BI_PASS:
        DC.B    $0D,$0A,"Pass ",0
STR_BI_COLON:
        DC.B    ": ",0
STR_BI_OK:
        DC.B    " ok",0
STR_BI_ERR:
        DC.B    " err",0
STR_BI_STOP:
        DC.B    $0D,$0A,"Stopped after ",0
STR_BI_STOP2:
        DC.B    " passes, ",0
STR_BI_STOP3:
        DC.B    " total errors.",$0D,$0A,0


;==============================================================================
;  NS_SCSI_SCAN - scan SCSI IDs 0-6, print vendor/model/capacity/geometry
;  Adapted from scsi.m68 v1.1. All registers preserved.
;==============================================================================
NS_SCSI_SCAN:
        MOVEM.L D0-D7/A0-A6,-(SP)

        BSR     NS_RESET_BUS

        MOVEQ   #0,D7                    ; D7 = target ID (0-6)

NS_SCAN_LOOP:
        LEA     NS_STR_ID,A0
        BSR     PRINTSTR
        MOVE.B  D7,D0
        ADD.B   #'0',D0
        BSR     PUTCHAR

        ; --- INQUIRY ---
        BSR     NS_SELECT_TARGET
        TST.L   D0
        BNE.W   .next

        LEA     NS_STR_FOUND,A0
        BSR     PRINTSTR

        LEA     NS_CDB_INQ,A5
        LEA     NS_DATA_BUF,A4
        BSR     NS_RUN_SM
        TST.B   D5
        BNE.W   .fail
        BSR     NS_PRINT_DRIVE_INFO

        ; --- READ CAPACITY ---
        BSR     NS_SELECT_TARGET
        TST.L   D0
        BNE.W   .next
        LEA     NS_CDB_CAP,A5
        LEA     NS_DATA_BUF,A4
        BSR     NS_RUN_SM
        TST.B   D5
        BNE.S   .no_cap
        BSR     NS_CALC_CAPACITY
.no_cap

        ; --- MODE SENSE geometry ---
        BSR     NS_SELECT_TARGET
        TST.L   D0
        BNE.W   .next
        LEA     NS_CDB_GEOM,A5
        LEA     NS_DATA_BUF,A4
        BSR     NS_RUN_SM
        TST.B   D5
        BNE.S   .no_geom
        BSR     NS_PRINT_GEOMETRY
.no_geom
        BRA.W   .next

.fail
        LEA     NS_STR_CHECK,A0
        BSR     PRINTSTR
.next
        BSR     NS_RELEASE_BUS
        ADDQ.L  #1,D7
        CMP.L   #7,D7
        BNE.W   NS_SCAN_LOOP

        LEA     NS_STR_DONE,A0
        BSR     PRINTSTR

        MOVEM.L (SP)+,D0-D7/A0-A6
        RTS


;--- NS_RUN_SM - SCSI state machine (command + data + status + msg phases) ---
; A5 = CDB pointer   A4 = data buffer
; Returns: D5.b = SCSI status byte (0 = GOOD)
NS_RUN_SM:
        MOVEQ   #0,D6                    ; byte counter
        MOVEQ   #-1,D5                   ; default status = error ($FF)

.sm_loop
        MOVE.L  #2000000,D0
.wreq
        MOVE.B  SCSI_STATUS,D2
        BTST    #STAT_REQ,D2
        BNE.S   .got_req
        BTST    #STAT_BSY,D2
        BEQ.W   .disconnected
        SUBQ.L  #1,D0
        BNE.S   .wreq
        RTS

.got_req
        MOVE.B  SCSI_STATUS,D3
        ANDI.B  #$1C,D3

        MOVE.B  D3,D1
        LSR.B   #2,D1
        MOVE.B  D1,SCSI_TCR

        CMP.B   #$08,D3
        BEQ.S   .skip_drop
        MOVE.B  #0,SCSI_ICR
.skip_drop

        CMP.B   #$08,D3
        BEQ.W   .do_cmd
        CMP.B   #$04,D3
        BEQ.W   .do_datain
        CMP.B   #$0C,D3
        BEQ.W   .do_status
        CMP.B   #$1C,D3
        BEQ.W   .do_msg
        BRA.W   .do_unknown

.do_cmd
        MOVE.B  (A5)+,D4
        MOVE.B  D4,SCSI_ODR
        MOVE.B  #$01,SCSI_ICR
        NOP
        NOP
        MOVE.B  #$11,SCSI_ICR
        BRA.S   .ack_wait

.do_datain
        MOVE.B  SCSI_ODR,D4
        MOVE.B  D4,(A4)+
        MOVE.B  #$10,SCSI_ICR
        BRA.S   .ack_wait

.do_status
        MOVE.B  SCSI_ODR,D4
        MOVE.B  D4,D5
        MOVE.B  #$10,SCSI_ICR
        BRA.S   .ack_wait

.do_msg
        MOVE.B  SCSI_ODR,D4
        MOVE.B  #$10,SCSI_ICR
        BRA.S   .ack_wait

.do_unknown
        MOVE.B  #$10,SCSI_ICR

.ack_wait
        MOVE.L  #2000000,D0
.wdrop
        MOVE.B  SCSI_STATUS,D2
        BTST    #STAT_REQ,D2
        BEQ.S   .req_dropped
        SUBQ.L  #1,D0
        BNE.S   .wdrop
        RTS

.req_dropped
        CMP.B   #$08,D3
        BEQ.S   .hold_dbus
        MOVE.B  #0,SCSI_ICR
        BRA.S   .drop_done
.hold_dbus
        MOVE.B  #$01,SCSI_ICR
.drop_done
        ADDQ.L  #1,D6
        CMP.L   #1000,D6
        BNE.W   .sm_loop
        RTS

.disconnected
        RTS


;--- NS_RESET_BUS ---
NS_RESET_BUS:
        MOVE.B  #0,SCSI_ICR
        MOVE.B  #0,SCSI_MR
        MOVE.B  #$80,SCSI_ICR
        MOVE.L  #200000,D0
.rl     SUBQ.L  #1,D0
        BNE.S   .rl
        MOVE.B  #0,SCSI_ICR
        MOVE.B  SCSI_RESET_REG,D0
        RTS


;--- NS_SELECT_TARGET - select D7 as target; returns D0=0 ok, D0=-1 empty ---
NS_SELECT_TARGET:
        MOVE.B  #0,SCSI_TCR
        MOVE.B  #0,SCSI_MR
        MOVEQ   #1,D0
        LSL.L   #7,D0                    ; self = ID7 bit = $80
        MOVEQ   #1,D1
        MOVE.L  D7,D2
        LSL.L   D2,D1                    ; target bit
        OR.B    D1,D0
        MOVE.B  D0,SCSI_ODR
        MOVE.B  #$01,SCSI_ICR
        MOVE.B  #$05,SCSI_ICR
        MOVE.L  #1000000,D0
.w
        MOVE.B  SCSI_STATUS,D2
        BTST    #STAT_BSY,D2
        BNE.S   .matched
        SUBQ.L  #1,D0
        BNE.S   .w
        MOVE.B  #0,SCSI_ICR
        LEA     NS_STR_EMPTY,A0
        BSR     PRINTSTR
        MOVEQ   #-1,D0
        RTS
.matched
        MOVE.B  #0,SCSI_ICR
        MOVE.L  #10000,D0
.d      SUBQ.L  #1,D0
        BNE.S   .d
        MOVEQ   #0,D0
        RTS


;--- NS_RELEASE_BUS ---
NS_RELEASE_BUS:
        MOVE.B  #0,SCSI_ICR
        MOVE.B  #0,SCSI_TCR
        RTS


;--- NS_PRINT_DRIVE_INFO - print vendor/model/rev from NS_DATA_BUF ---
NS_PRINT_DRIVE_INFO:
        LEA     NS_STR_VENDOR,A0
        BSR     PRINTSTR
        LEA     NS_DATA_BUF+8,A0
        MOVEQ   #7,D1
.v      MOVE.B  (A0)+,D0
        BSR     PUTCHAR
        DBF     D1,.v
        LEA     NS_STR_MODEL,A0
        BSR     PRINTSTR
        LEA     NS_DATA_BUF+16,A0
        MOVEQ   #15,D1
.m      MOVE.B  (A0)+,D0
        BSR     PUTCHAR
        DBF     D1,.m
        LEA     NS_STR_REV,A0
        BSR     PRINTSTR
        LEA     NS_DATA_BUF+32,A0
        MOVEQ   #3,D1
.r      MOVE.B  (A0)+,D0
        BSR     PUTCHAR
        DBF     D1,.r
        MOVE.B  #']',D0
        BSR     PUTCHAR
        BSR     PRINT_CRLF
        RTS


;--- NS_CALC_CAPACITY - print capacity in MB from READ CAPACITY response ---
NS_CALC_CAPACITY:
        MOVE.L  NS_DATA_BUF,D0           ; max LBA
        ADDQ.L  #1,D0                    ; total blocks
        LSR.L   #1,D0                    ; /2 - assumes 512-byte blocks → KB
        MOVE.L  D0,D1
        MOVEQ   #10,D2
        LSR.L   D2,D1                    ; D1 = MB
        LEA     NS_STR_CAP,A0
        BSR     PRINTSTR
        MOVE.L  D1,D0
        BSR     NS_PRINT_DEC
        LEA     NS_STR_MB,A0
        BSR     PRINTSTR
        RTS


;--- NS_PRINT_GEOMETRY - print cylinders/heads from MODE SENSE page 04 ---
NS_PRINT_GEOMETRY:
        LEA     NS_DATA_BUF+4,A0
        CMP.B   #$04,(A0)
        BNE.S   .not_p4

        LEA     NS_STR_CYLS,A0
        BSR     PRINTSTR
        MOVEQ   #0,D0
        MOVE.B  NS_DATA_BUF+6,D0
        LSL.L   #8,D0
        MOVE.B  NS_DATA_BUF+7,D0
        LSL.L   #8,D0
        MOVE.B  NS_DATA_BUF+8,D0
        BSR     NS_PRINT_DEC

        LEA     NS_STR_HEADS,A0
        BSR     PRINTSTR
        MOVEQ   #0,D0
        MOVE.B  NS_DATA_BUF+9,D0
        BSR     NS_PRINT_DEC

        BSR     PRINT_CRLF
.not_p4
        RTS


;--- NS_PRINT_DEC - print D0.l as unsigned decimal ---
NS_PRINT_DEC:
        MOVEM.L D0-D3/A1,-(SP)
        SUBA.W  #12,SP
        LEA     12(SP),A1                ; point to TOP of buffer; -(A1) stores within it
        MOVEQ   #0,D2
        MOVEQ   #0,D3
.lp
        DIVU.L  #10,D3:D0
        ADDI.B  #'0',D3
        MOVE.B  D3,-(A1)
        ADDQ.L  #1,D2
        MOVEQ   #0,D3
        TST.L   D0
        BNE.S   .lp
.pr
        MOVE.B  (A1)+,D0
        BSR     PUTCHAR
        SUBQ.L  #1,D2
        BNE.S   .pr
        ADDA.W  #12,SP
        MOVEM.L (SP)+,D0-D3/A1
        RTS


;--- SCSI string constants and CDB tables ---
        EVEN
NS_CDB_INQ:     DC.B    $12,0,0,0,36,0
NS_CDB_CAP:     DC.B    $25,0,0,0,0,0,0,0,0,0
NS_CDB_GEOM:    DC.B    $1A,0,$04,0,36,0

NS_STR_ID:      DC.B    $0D,$0A,"ID ",0
NS_STR_FOUND:   DC.B    " FOUND: ",0
NS_STR_EMPTY:   DC.B    " empty",0
NS_STR_CHECK:   DC.B    " (CHECK CONDITION)",$0D,$0A,0
NS_STR_DONE:    DC.B    $0D,$0A,"Scan complete.",$0D,$0A,0
NS_STR_VENDOR:  DC.B    "[",0
NS_STR_MODEL:   DC.B    "] [",0
NS_STR_REV:     DC.B    "] REV [",0
NS_STR_CAP:     DC.B    " -> Capacity: ",0
NS_STR_MB:      DC.B    " MB",$0D,$0A,0
NS_STR_CYLS:    DC.B    " -> Geometry: Cyls [",0
NS_STR_HEADS:   DC.B    "] Heads [",0


