;******************************************************************************
;
;  AGFA-MON - Machine Language Monitor for Agfa Compugraphic 9000PS
;
;  Target CPU : Motorola 68020
;  Serial I/O : Zilog Z85C30 SCC Channel A (RS-232 DE-9)
;               Control $07000002 / Data $07000003
;  ROM        : 128KB at $00000000 (4x AM27C256, 32-bit interleave)
;  RAM        : 4MB at $02000000-$023FFFFF
;
;  Assemble with:
;    vasmm68k_mot -m68020 -Fbin -o agfa-rom.bin agfa-mon.m68
;
;  API jump table (compatible with I/O board for EhBASIC):
;    $0400  JMP START       cold start
;    $0406  JMP PUTCHAR     output D0.b to serial
;    $040C  JMP GETCHAR     blocking input into D0.b
;    $0412  JMP PRINTSTR    print NUL-terminated string at A0
;    $0418  JMP GETLINE     read line into buffer at A0
;    $041E  JMP CMD_LOOP    return to monitor prompt
;    $0424  JMP GETTICKS    return tick count in D0.L (~60Hz)
;
;  Reserved for future API entries: $042A-$045F
;  START code begins at $0460.
;
;******************************************************************************

; ─── Z85C30 SCC ───────────────────────────────────────────────────────────────
SCC_A_CTRL      EQU     $07000002   ; Ch A control port (RR0 / WRn)
SCC_A_DATA      EQU     $07000003   ; Ch A data port

; ─── Memory map ───────────────────────────────────────────────────────────────
STACK_TOP       EQU     $02400000   ; initial supervisor stack (top of 4MB+guard)

; Monitor workspace:
;   $02004000  LINE_BUF  [80 bytes]
;   $02004050  SAVE_D0   [32 bytes]  D0-D7
;   $02004070  SAVE_A0   [28 bytes]  A0-A6
;   $02004090  SAVE_PC   [ 4 bytes]
;   $02004094  SAVE_SR   [ 2 bytes]
;   $02004096  CONFIG_BUF [40 bytes] NVRAM working copy
;   $02004100  VT_VEC_*  [128 bytes] VERA dispatch JMP thunks
;   $02004500  VT_RAM    [~5KB]      VERA text routines (copied from ROM)

LINE_BUF        EQU     $02004000
LINE_BUF_SZ     EQU     80
SAVE_D0         EQU     $02004050
SAVE_A0         EQU     $02004070
SAVE_PC         EQU     $02004090
SAVE_SR         EQU     $02004094
CONFIG_BUF      EQU     $02004096   ; 40-byte NVRAM working copy

; NVRAM field offsets into CONFIG_BUF
NV_CONSOLE_OUT  EQU     16          ; byte: bits[1:0] console I/O mode
                                    ;   bit 0: 0=serial out  1=VERA out
                                    ;   bit 1: 0=RS232 in    1=PS/2 in

; EhBASIC area
BASIC_RAM       EQU     $02008000
BASIC_SIZE      EQU     $00040000   ; 256KB

; Boot RAM test range
;   Start: $02008000 - above monitor workspace ($02004000-$02004097)
;   End:   $023F0000 - leaves 64KB below stack top ($02400000) for headroom
RAM_TEST_START  EQU     $02008000
RAM_TEST_END    EQU     $023F0000
RAM_MAX_ERRS    EQU     8           ; max errors reported per pattern before suppressing

; AM5380 SCSI registers (stride-1 from $05000000)
SCSI_ODR        EQU     $05000000
SCSI_ICR        EQU     $05000001
SCSI_MR         EQU     $05000002
SCSI_TCR        EQU     $05000003
SCSI_STATUS     EQU     $05000004
SCSI_BSR        EQU     $05000005
SCSI_RESET_REG  EQU     $05000007
STAT_REQ        EQU     5
STAT_BSY        EQU     6

; RAM buffer used by ROM SCSI scanner (in CMD_SCSI, no user input needed)
NS_DATA_BUF     EQU     LINE_BUF    ; 80 bytes - enough for 36-byte INQUIRY/MODE SENSE


;******************************************************************************
;  EXCEPTION VECTOR TABLE   ORG $000000
;******************************************************************************

        ORG     $000000

        DC.L    STACK_TOP           ; $000 Initial SSP
        DC.L    START               ; $004 Initial PC
        DC.L    BUSERR_HANDLER      ; $008 Bus Error
        DC.L    ADDRERR_HANDLER     ; $00C Address Error
        DC.L    ILLEGAL_HANDLER     ; $010 Illegal Instruction
        DC.L    GENERIC_HANDLER     ; $014 Zero Divide
        DC.L    GENERIC_HANDLER     ; $018 CHK/CHK2
        DC.L    GENERIC_HANDLER     ; $01C TRAPV
        DC.L    GENERIC_HANDLER     ; $020 Privilege Violation
        DC.L    GENERIC_HANDLER     ; $024 Trace
        DC.L    GENERIC_HANDLER     ; $028 Line 1010 Emulator
        DC.L    GENERIC_HANDLER     ; $02C Line 1111 Emulator
        DC.L    GENERIC_HANDLER     ; $030 Hardware Breakpoint
        DC.L    GENERIC_HANDLER     ; $034 (reserved)
        DC.L    GENERIC_HANDLER     ; $038 Format Error
        DC.L    GENERIC_HANDLER     ; $03C Uninitialised Interrupt
        REPT    8
        DC.L    GENERIC_HANDLER     ; $040-$05C reserved
        ENDR
        DC.L    GENERIC_HANDLER     ; $060 Spurious Interrupt
        DC.L    GENERIC_HANDLER     ; $064 Level 1 Autovector
        DC.L    GENERIC_HANDLER     ; $068 Level 2 Autovector
        DC.L    GENERIC_HANDLER     ; $06C Level 3 Autovector
        DC.L    GENERIC_HANDLER     ; $070 Level 4 Autovector
        DC.L    GENERIC_HANDLER     ; $074 Level 5 Autovector
        DC.L    GENERIC_HANDLER     ; $078 Level 6 Autovector
        DC.L    GENERIC_HANDLER     ; $07C NMI
        REPT    16
        DC.L    GENERIC_HANDLER     ; $080-$0BC TRAP #0-#15
        ENDR
        REPT    16
        DC.L    GENERIC_HANDLER     ; $0C0-$0FC FP + reserved
        ENDR
        REPT    192
        DC.L    GENERIC_HANDLER     ; $100-$3FC User vectors
        ENDR


;******************************************************************************
;  API JUMP TABLE  - fixed addresses (I/O board compatible)
;******************************************************************************

        ORG     $000400
        JMP     START               ; $0400 START_VEC
        ORG     $000406
        JMP     PUTCHAR             ; $0406 PUT_VEC
        ORG     $00040C
        JMP     GETCHAR             ; $040C GET_VEC
        ORG     $000412
        JMP     PRINTSTR            ; $0412 PRT_VEC
        ORG     $000418
        JMP     GETLINE             ; $0418 GL_VEC
        ORG     $00041E
        JMP     CMD_LOOP            ; $041E EXIT_VEC
        ORG     $000424
        JMP     GETTICKS            ; $0424 GETTICKS_VEC


;******************************************************************************
;  START - cold-boot entry point
;******************************************************************************

        ORG     $000460
START:
        MOVE.L  #$0001,D0
        MOVEC   D0,CACR             ; enable 68020 instruction cache
        MOVEA.L #STACK_TOP,SP       ; establish supervisor stack

        ; Zero monitor register-save area ($02004050-$02004097, 72 bytes = 18 lwords)
        MOVEA.L #SAVE_D0,A0
        MOVE.L  #(SAVE_SR+4-SAVE_D0)/4-1,D0
.clr    CLR.L   (A0)+
        DBF     D0,.clr

        ; Hardware register writes -- required before first SCC access.
        ; Original ROM (detect_ram_top at $1a6e) writes these before TST.B $07000020.
        ; Without them the PAL controlling the $07000000 region does not assert
        ; DTACK, causing BERR on every SCC access and an immediate double bus fault.
        ; Verified: omitting these writes causes halt; adding them fixes it.
        MOVE.L  #$FFFFFFFF,$06100000    ; rendering controller reset
        CLR.L   $06080000               ; FIFO/hardware register clear
        CLR.L   $060C0000               ; FIFO/hardware register clear

        BSR     INIT_HW
        LEA     STR_BANNER,A0
        BSR     PRINTSTR
        LEA     STR_BUILD_VERSION,A0
        BSR     PRINTSTR

        ; Load NVRAM config
        BSR     LOAD_CONFIG

        ; Detect and initialize VERA if present
        BSR     VERA_DETECT
        TST.B   D0
        BEQ.S   .no_vera

        ; Temporarily force serial output during VERA init.
        ; VERA_INIT sets VT_MAGIC but JMP thunks aren't ready until
        ; VT_INIT_VECTORS completes.  If NV_CONSOLE_OUT bit 0 is set,
        ; PUTCHAR would redirect to uninitialized thunks → crash.
        MOVE.B  CONFIG_BUF+NV_CONSOLE_OUT,D3
        CLR.B   CONFIG_BUF+NV_CONSOLE_OUT

        BSR     VERA_INIT
        BSR     VT_INIT_RAM
        BSR     VT_INIT_VECTORS

        MOVE.B  D3,CONFIG_BUF+NV_CONSOLE_OUT   ; restore VERA redirect

        BSR     VERA_IRQ_INIT           ; VSYNC cursor blink + TICK_COUNT
        BRA.S   .irq_done

.no_vera:
        BSR     VIA_TIMER_INIT          ; 60Hz tick via VIA #1 T1 (no cursor, no VERA)

.irq_done:
        BSR     RAM_TEST_BOOT           ; quick AA/55 check before handing off to user
        LEA     STR_HELP,A0
        BSR     PRINTSTR
        ; fall through


;******************************************************************************
;  CMD_LOOP - main command dispatcher
;******************************************************************************

CMD_LOOP:
        LEA     STR_PROMPT,A0
        BSR     PRINTSTR
        LEA     LINE_BUF,A0
        BSR     GETLINE             ; A0 = buffer base (unchanged); NUL-terminated

        MOVEA.L A0,A1               ; A1 = parse cursor
        BSR     SKIP_SPACES_A1

        MOVE.B  (A1)+,D0
        CMPI.B  #$61,D0             ; fold to upper
        BLT.S   .uc
        CMPI.B  #$7A,D0
        BGT.S   .uc
        SUBI.B  #$20,D0
.uc
        CMP.B   #'H',D0
        BEQ     CMD_HELP
        CMP.B   #'?',D0
        BEQ     CMD_HELP
        CMP.B   #'D',D0
        BEQ     CMD_DUMP
        CMP.B   #'E',D0
        BEQ     CMD_EXAMINE
        CMP.B   #'F',D0
        BEQ     CMD_FILL
        CMP.B   #'M',D0
        BEQ     CMD_MOVE
        CMP.B   #'G',D0
        BEQ     CMD_GO
        CMP.B   #'R',D0
        BEQ     CMD_REGS
        CMP.B   #'L',D0
        BEQ     CMD_LOAD
        CMP.B   #'P',D0
        BEQ     CMD_PUT
        CMP.B   #'B',D0
        BEQ     CMD_BASIC
        CMP.B   #'S',D0
        BEQ     CMD_SCSI
        CMP.B   #'C',D0
        BEQ     CMD_CPM
        CMP.B   #'U',D0
        BEQ     CMD_UNIX
        CMP.B   #'T',D0
        BEQ     CMD_TEST
        CMP.B   #'X',D0
        BEQ     CMD_XBASIC
        CMP.B   #'V',D0
        BEQ     CMD_VERA_CFG
        CMPI.B  #0,D0
        BEQ     CMD_LOOP            ; blank line
        LEA     STR_WHAT,A0
        BSR     PRINTSTR
        BRA     CMD_LOOP


;******************************************************************************
;  H / ? - help
;******************************************************************************
CMD_HELP:
        LEA     STR_HELP,A0
        BSR     PRINTSTR
        BRA     CMD_LOOP


;******************************************************************************
;  D addr [len] - hex/ASCII dump (default 128 bytes)
;******************************************************************************
CMD_DUMP:
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A2               ; A2 = dump address
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1        ; D0 = length
        TST.L   D0
        BNE.S   .gl
        MOVE.L  #$80,D0
.gl     MOVE.L  D0,D7               ; D7 = bytes remaining

.row    BTST    #0,SCC_A_CTRL       ; any key pressed?
        BEQ.S   .cnt
        MOVE.B  SCC_A_DATA,D0      ; discard key, abort dump
        BRA     CMD_LOOP
.cnt    TST.L   D7
        BEQ     CMD_LOOP

        MOVE.L  A2,D0
        BSR     PRINT_HEX8
        MOVE.B  #':',D0
        BSR     PUTCHAR
        MOVE.B  #' ',D0
        BSR     PUTCHAR

        MOVE.L  #16,D5
        CMP.L   D5,D7
        BHI.S   .full
        MOVE.L  D7,D5               ; D5 = bytes this row
.full   MOVE.L  D5,D4               ; D4 = bytes this row (saved)
        MOVEA.L A2,A3               ; A3 = row start (ASCII pass)
        MOVE.L  D5,D6               ; D6 = hex count

.hx     MOVE.B  (A2)+,D0
        BSR     PRINT_HEX2
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        SUBQ.L  #1,D6
        BNE.S   .hx

        MOVE.L  #16,D6
        SUB.L   D4,D6               ; D6 = pad columns
.pad    TST.L   D6
        BEQ.S   .asc
        LEA     STR_3SP,A0
        BSR     PRINTSTR
        SUBQ.L  #1,D6
        BRA.S   .pad

.asc    MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVE.L  D4,D6
.ac     MOVE.B  (A3)+,D0
        CMPI.B  #$20,D0
        BLT.S   .dot
        CMPI.B  #$7E,D0
        BLE.S   .pr
.dot    MOVE.B  #'.',D0
.pr     BSR     PUTCHAR
        SUBQ.L  #1,D6
        BNE.S   .ac

        BSR     PRINT_CRLF
        SUB.L   D4,D7
        BRA.W   .row


;******************************************************************************
;  E <addr> - interactive examine/edit memory
;  Shows address: current_byte, accepts new hex value or Enter to keep.
;  Type . to quit and return to prompt.
;******************************************************************************
CMD_EXAMINE:
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A2               ; A2 = current address

.next   MOVE.L  A2,D0               ; print address
        BSR     PRINT_HEX8
        LEA     STR_COLON_SP,A0
        BSR     PRINTSTR
        MOVE.B  (A2),D0             ; print current byte
        BSR     PRINT_HEX2
        MOVE.B  #' ',D0
        BSR     PUTCHAR

        LEA     LINE_BUF,A0         ; read user input into line buffer
        BSR     GETLINE
        MOVEA.L A0,A1               ; A1 = parse cursor
        BSR     SKIP_SPACES_A1

        MOVE.B  (A1),D0             ; check first char
        BEQ.W   .adv                ; empty line = keep byte, advance
        CMP.B   #'.',D0
        BEQ     CMD_LOOP            ; '.' = exit
        CMP.B   #'q',D0
        BEQ     CMD_LOOP
        CMP.B   #'Q',D0
        BEQ     CMD_LOOP

        BSR     PARSE_HEX_A1        ; parse new value
        MOVE.B  D0,(A2)             ; write byte

.adv    ADDQ.L  #1,A2
        BRA.W   .next


;******************************************************************************
;  F addr len byte - fill
;******************************************************************************
CMD_FILL:
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A2
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVE.L  D0,D7
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVE.B  D0,D6
.fl     TST.L   D7
        BEQ     CMD_LOOP
        MOVE.B  D6,(A2)+
        SUBQ.L  #1,D7
        BRA.S   .fl


;******************************************************************************
;  M src dst len - copy
;******************************************************************************
CMD_MOVE:
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A2
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A3
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVE.L  D0,D7
.ml     TST.L   D7
        BEQ     CMD_LOOP
        MOVE.B  (A2)+,(A3)+
        SUBQ.L  #1,D7
        BRA.S   .ml


;******************************************************************************
;  G [addr] - execute user code
;
;  Restores D0-D7 and A1-A6 from save area.
;  A0 = call address. User's saved A0 is NOT restored (A0 is the call target).
;  On return: saves all registers, resets stack, displays register context.
;******************************************************************************
CMD_GO:
        BSR     SKIP_SPACES_A1
        TST.B   (A1)
        BEQ.S   .use_saved
        BSR     PARSE_HEX_A1
        MOVE.L  D0,SAVE_PC
.use_saved
        MOVEA.L SAVE_PC,A0          ; A0 = call target
        MOVEM.L SAVE_D0,D0-D7       ; restore user D0-D7
        MOVEM.L SAVE_A0+4,A1-A6    ; restore user A1-A6 (skip A0 slot)
        JSR     (A0)                ; call user code
        MOVEM.L D0-D7,SAVE_D0       ; save result D0-D7
        MOVEM.L A0-A6,SAVE_A0       ; save result A0-A6
        MOVEA.L #STACK_TOP,SP       ; reset monitor stack
        LEA     STR_RETURNED,A0
        BSR     PRINTSTR
        BRA     CMD_REGS_SHOW


;******************************************************************************
;  R - display registers
;******************************************************************************
CMD_REGS:
CMD_REGS_SHOW:
        LEA     STR_D_LABEL,A0
        BSR     PRINTSTR
        MOVEA.L #SAVE_D0,A2
        MOVEQ   #7,D7
.dl     MOVE.L  (A2)+,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        DBF     D7,.dl
        BSR     PRINT_CRLF

        LEA     STR_A_LABEL,A0
        BSR     PRINTSTR
        MOVEA.L #SAVE_A0,A2
        MOVEQ   #6,D7
.al     MOVE.L  (A2)+,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        DBF     D7,.al
        BSR     PRINT_CRLF

        LEA     STR_PC_SR,A0
        BSR     PRINTSTR
        MOVE.L  SAVE_PC,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVE.W  SAVE_SR,D0
        BSR     PRINT_HEX4
        BSR     PRINT_CRLF

        LEA     STR_CTRL,A0
        BSR     PRINTSTR
        MOVEC   VBR,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVEC   CACR,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVEC   ISP,D0
        BSR     PRINT_HEX8
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVEC   MSP,D0
        BSR     PRINT_HEX8
        BSR     PRINT_CRLF

        BRA     CMD_LOOP


;******************************************************************************
;  P <addr> <len> -- output S3 records (memory -> terminal)
;  Uses S3 (4-byte address) + S7 terminator to match vasm -Fsrec output.
;******************************************************************************
CMD_PUT:
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVEA.L D0,A2
        BSR     SKIP_SPACES_A1
        BSR     PARSE_HEX_A1
        MOVE.L  D0,D7
        TST.L   D7
        BEQ     CMD_LOOP
        BSR     EMIT_SRECS
        BRA     CMD_LOOP


;******************************************************************************
;  EMIT_SRECS -- output S3 records for a memory region, then S7 terminator
;  Input : A2 = start address, D7 = byte count
;  Clobbers: A2, D3-D7
;******************************************************************************
EMIT_SRECS:
        MOVE.B  CONFIG_BUF+NV_CONSOLE_OUT,-(SP)
        CLR.B   CONFIG_BUF+NV_CONSOLE_OUT
.row    TST.L   D7
        BEQ.S   .term

        MOVE.L  #32,D6
        CMP.L   D6,D7
        BHI.S   .full
        MOVE.L  D7,D6               ; D6 = data bytes this record
.full
        ; byte count = data + 5 (4 addr bytes + 1 checksum)
        MOVE.L  D6,D5
        ADDQ.L  #5,D5               ; D5 = byte count

        MOVE.B  #'S',D0
        BSR     PUTCHAR
        MOVE.B  #'3',D0
        BSR     PUTCHAR
        MOVE.L  D5,D0
        BSR     PRINT_HEX2
        MOVE.L  D5,D4               ; D4 = checksum accumulator (byte count)

        ; Address bytes MSB first.
        ; NOTE: checksum ADD must come BEFORE PRINT_HEX2 because PRINT_HEX2
        ; clobbers D0 (leaves ASCII value of low hex nibble on return).
        ; byte 3: bits 31:24
        MOVE.L  A2,D0
        MOVE.L  D0,D3
        SWAP    D3
        LSR.L   #8,D3
        MOVE.L  D3,D0
        ADD.B   D0,D4               ; checksum before print
        BSR     PRINT_HEX2
        ; byte 2: bits 23:16
        MOVE.L  A2,D0
        SWAP    D0
        ADD.B   D0,D4
        BSR     PRINT_HEX2
        ; byte 1: bits 15:8
        MOVE.L  A2,D0
        LSR.L   #8,D0
        ADD.B   D0,D4
        BSR     PRINT_HEX2
        ; byte 0: bits 7:0
        MOVE.L  A2,D0
        ADD.B   D0,D4
        BSR     PRINT_HEX2

        ; data bytes
        MOVE.L  D6,D5
.dat    MOVE.B  (A2)+,D0
        ADD.B   D0,D4
        BSR     PRINT_HEX2
        SUBQ.L  #1,D5
        BNE.S   .dat

        NOT.B   D4
        MOVE.B  D4,D0
        BSR     PRINT_HEX2
        BSR     PRINT_CRLF
        SUB.L   D6,D7
        BRA.W   .row

.term   LEA     STR_S7_TERM,A0
        BSR     PRINTSTR
        MOVE.B  (SP)+,CONFIG_BUF+NV_CONSOLE_OUT
        RTS


;******************************************************************************
;  L -- load S-records (S1/S2/S3 data, S7/S8/S9 terminates)
;  S0 header and unrecognised types are drained and skipped.
;  S7 is the standard terminator for S3-series files (vasm -Fmots default).
;******************************************************************************
CMD_LOAD:
        LEA     STR_SREC_PROMPT,A0
        BSR     PRINTSTR
        MOVEQ   #0,D7               ; D7 = first-record flag (0 = not yet seen)

.rec
        ; wait for 'S'
.sync   BSR     GETCHAR
        CMP.B   #'S',D0
        BNE.S   .sync

        BSR     GETCHAR             ; record type digit
        CMP.B   #'7',D0             ; S7 -- end of S3-series (vasm default)
        BEQ.W   .done
        CMP.B   #'8',D0             ; S8 -- end of S2-series
        BEQ.W   .done
        CMP.B   #'9',D0             ; S9 -- end of S1-series
        BEQ.W   .done
        CMP.B   #'1',D0
        BEQ.W   .is_s1
        CMP.B   #'2',D0
        BEQ.W   .is_s2
        CMP.B   #'3',D0
        BEQ.W   .is_s3
        ; S0 header or unknown type -- drain line and continue
        BSR     DRAIN_LINE
        BRA.W   .rec

        ; S1: 2-byte address, byte_count includes 2 addr + 1 cksum
.is_s1  BSR     GET_HEX_BYTE
        MOVE.B  D0,D6
        MOVE.B  D6,D4
        MOVEQ   #0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        SUBQ.B  #3,D6               ; data bytes = byte_count - 2 addr - 1 cksum
        BRA.S   .data

        ; S2: 3-byte address, byte_count includes 3 addr + 1 cksum
.is_s2  BSR     GET_HEX_BYTE
        MOVE.B  D0,D6
        MOVE.B  D6,D4
        MOVEQ   #0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        SUBQ.B  #4,D6               ; data bytes = byte_count - 3 addr - 1 cksum
        BRA.S   .data

        ; S3: 4-byte address, byte_count includes 4 addr + 1 cksum
.is_s3  BSR     GET_HEX_BYTE
        MOVE.B  D0,D6
        MOVE.B  D6,D4
        MOVEQ   #0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        LSL.L   #8,D3
        OR.B    D0,D3
        SUBQ.B  #5,D6               ; data bytes = byte_count - 4 addr - 1 cksum

.data   MOVEA.L D3,A2
        ; On first data record, save load address for bare G command
        TST.L   D7
        BNE.S   .nodfl
        MOVE.L  D3,SAVE_PC
        MOVEQ   #1,D7
.nodfl  MOVE.B  D6,D5
.dl     SUBQ.B  #1,D5
        BMI.S   .ck
        BSR     GET_HEX_BYTE
        ADD.B   D0,D4
        MOVE.B  D0,(A2)+
        BRA.S   .dl
.ck     BSR     GET_HEX_BYTE        ; checksum byte
        ADD.B   D0,D4
        CMP.B   #$FF,D4
        BNE.S   .ckerr
        MOVE.B  #'.',D0             ; '.' = record OK
        BSR     PUTCHAR
        BRA.W   .rec
.ckerr  MOVE.B  #'!',D0             ; '!' = checksum error
        BSR     PUTCHAR
        BRA.W   .rec

.done   BSR     DRAIN_LINE          ; consume rest of S7/S8/S9 line
        LEA     STR_LOAD_OK,A0
        BSR     PRINTSTR            ; "OK"
        TST.L   D7
        BEQ.S   .noaddr
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVE.L  SAVE_PC,D0
        BSR     PRINT_HEX8          ; print start address of loaded program
.noaddr BSR     PRINT_CRLF
        BRA     CMD_LOOP


; Read two ASCII hex digits from serial → D0.b, preserves D1
GET_HEX_BYTE:
        BSR     GETCHAR
        BSR     NYBBLE
        LSL.B   #4,D0
        MOVE.B  D0,D1
        BSR     GETCHAR
        BSR     NYBBLE
        OR.B    D1,D0
        RTS

; ASCII hex char D0 -> nybble value D0
NYBBLE:
        SUBI.B  #'0',D0
        CMPI.B  #9,D0
        BLE.S   .ok
        SUBI.B  #7,D0
        ANDI.B  #$0F,D0
.ok     RTS


; DRAIN_LINE -- read and discard serial chars until CR or LF
DRAIN_LINE:
.dl     BSR     GETCHAR
        CMP.B   #$0D,D0
        BEQ.S   .dld
        CMP.B   #$0A,D0
        BNE.S   .dl
.dld    RTS


;******************************************************************************
;  X - save BASIC program as S-records
;  Saves BASIC_RAM+$0100 (LAB_WARM + I/O vectors + pointers) through the end
;  of the program text.  Loading these records and warm-starting restores the
;  exact program that was running at the time of the save.
;******************************************************************************
CMD_XBASIC:
        ; Check BASIC has been cold-started (warm-start JMP opcode present)
        MOVE.W  BASIC_RAM+LAB_WARM,D0
        CMP.W   #$4EF9,D0
        BNE.S   .noinit

        ; Find end of program by following long next-line pointers from Smeml
        MOVEA.L BASIC_RAM+Smeml,A3  ; A3 = absolute start of program text
.scan   MOVE.L  (A3),D0             ; read next-line pointer (long, $00000000 = EOT)
        BEQ.S   .found
        MOVEA.L D0,A3               ; follow pointer to next line
        BRA.S   .scan
.found  ADDQ.L  #4,A3               ; skip past the $00000000 terminator long

        ; Emit S3 records from LAB_WARM through end of program
        MOVEA.L #BASIC_RAM+LAB_WARM,A2
        MOVE.L  A3,D7
        SUB.L   A2,D7               ; D7 = byte count
        BLE     CMD_LOOP
        BSR     EMIT_SRECS
        BRA     CMD_LOOP

.noinit LEA     STR_BASIC_NOINIT,A0
        BSR     PRINTSTR
        BRA     CMD_LOOP


;******************************************************************************
;  B - launch EhBASIC
;******************************************************************************
CMD_BASIC:
        ; Check if BASIC RAM has been initialised (cold start writes JMP opcode there)
        MOVE.W  BASIC_RAM+LAB_WARM,D0
        CMP.W   #$4EF9,D0
        BNE.S   .cold               ; Not yet initialised -- must cold start
        LEA     STR_COLDWARM,A0
        BSR     PRINTSTR
        BSR     GETCHAR
        BSR     PRINT_CRLF
        ANDI.B  #$DF,D0
        CMP.B   #'W',D0
        BNE.S   .cold
        MOVEA.L #BASIC_RAM,A3       ; EhBASIC warm start needs A3 = RAM base
        JMP     BASIC_RAM+LAB_WARM  ; warm start -- program intact
.cold   JMP     BASIC_START         ; cold start


;******************************************************************************
;  EXCEPTION HANDLERS  - reset SP then restart monitor
;******************************************************************************

;******************************************************************************
;  Unified exception handler - extracts PC and vector from the 68020
;  exception frame before resetting SP.
;
;  68020 exception frame (all formats):
;    SP+0:  saved SR        (word)
;    SP+2:  saved PC        (longword)
;    SP+6:  format/vector   (word: [15:12]=format, [11:0]=vector offset)
;
;  Bus Error (format $A/$B) and Address Error have larger frames, but
;  SR/PC/Format are always at the same offsets from the top of the frame.
;
;  Output example:
;    ** EXCEPTION at PC=$00005234  Vec=$064 (IPL-1 Autovector)  SR=$2000 **
;******************************************************************************

BUSERR_HANDLER:
ADDRERR_HANDLER:
ILLEGAL_HANDLER:
GENERIC_HANDLER:
        ; Extract exception info from the frame BEFORE resetting SP.
        ; Use A1 as scratch - we're about to reset SP anyway.
        MOVE.W  (SP),D3             ; D3 = saved SR
        MOVE.L  2(SP),D4            ; D4 = saved PC (faulting instruction)
        MOVE.W  6(SP),D5            ; D5 = format/vector word

        ; Now safe to reset SP and reinit hardware
        MOVEA.L #STACK_TOP,SP
        ORI.W   #$0700,SR           ; mask all interrupts - prevent ISR during crash report
        BSR     INIT_HW             ; SCC may not be initialised yet if fault fired early

        ; Print to serial only (VERA may be in a bad state)
        LEA     STR_EXC_HDR,A0
        BSR     PRINTSTR_SERIAL

        ; Print PC
        MOVE.L  D4,D0
        BSR     PRINT_HEX8_SERIAL

        ; Print vector offset
        LEA     STR_EXC_VEC,A0
        BSR     PRINTSTR_SERIAL
        MOVE.W  D5,D0
        ANDI.W  #$0FFF,D0           ; isolate vector offset (lower 12 bits)
        BSR     PRINT_HEX4_SERIAL

        ; Print vector name if known
        BSR     EXC_PRINT_NAME

        ; Print SR
        LEA     STR_EXC_SR,A0
        BSR     PRINTSTR_SERIAL
        MOVE.W  D3,D0
        BSR     PRINT_HEX4_SERIAL

        ; Print format nibble
        LEA     STR_EXC_FMT,A0
        BSR     PRINTSTR_SERIAL
        MOVE.W  D5,D0
        LSR.W   #8,D0
        LSR.W   #4,D0               ; format nibble in low 4 bits
        BSR     HEX_NYBBLE_SERIAL

        LEA     STR_EXC_TAIL,A0
        BSR     PRINTSTR_SERIAL
        BSR     FLUSH_TX

        ; Wait for keypress then reboot
        BSR     FLUSH_TX
        BSR     GETCHAR
        ; Print newline and wait for SCC to finish transmitting
        MOVE.B  #$0D,D0
        BSR     PUTCHAR_SER_EXC
        MOVE.B  #$0A,D0
        BSR     PUTCHAR_SER_EXC
        BSR     FLUSH_TX
        BRA     START


; --- Serial-only output routines for exception handler ---
; These bypass VERA/PUTCHAR entirely to avoid re-entering buggy code.

PRINTSTR_SERIAL:
        MOVEM.L D0,-(SP)
.ps     MOVE.B  (A0)+,D0
        BEQ.S   .psd
        BSR.S   PUTCHAR_SER_EXC
        BRA.S   .ps
.psd    MOVEM.L (SP)+,D0
        RTS

PUTCHAR_SER_EXC:
.txw    BTST    #2,SCC_A_CTRL
        BEQ.S   .txw
        MOVE.B  D0,SCC_A_DATA
        RTS

PRINT_HEX8_SERIAL:
        MOVEM.L D1-D2,-(SP)
        MOVE.L  D0,D1
        MOVEQ   #7,D2
.h8s    ROL.L   #4,D1
        MOVE.B  D1,D0
        ANDI.B  #$0F,D0
        BSR.S   HEX_NYBBLE_SERIAL
        DBF     D2,.h8s
        MOVEM.L (SP)+,D1-D2
        RTS

PRINT_HEX4_SERIAL:
        MOVEM.L D1-D2,-(SP)
        MOVE.W  D0,D1
        MOVEQ   #3,D2
.h4s    ROL.W   #4,D1
        MOVE.B  D1,D0
        ANDI.B  #$0F,D0
        BSR.S   HEX_NYBBLE_SERIAL
        DBF     D2,.h4s
        MOVEM.L (SP)+,D1-D2
        RTS

HEX_NYBBLE_SERIAL:
        ANDI.B  #$0F,D0
        ADDI.B  #'0',D0
        CMPI.B  #'9',D0
        BLE.S   .hns_ok
        ADDI.B  #7,D0
.hns_ok BSR.S   PUTCHAR_SER_EXC
        RTS


; --- Vector name lookup ---
EXC_PRINT_NAME:
        MOVE.W  D5,D0
        ANDI.W  #$0FFF,D0
        CMP.W   #$008,D0
        BEQ.S   .bus
        CMP.W   #$00C,D0
        BEQ.S   .addr
        CMP.W   #$010,D0
        BEQ.S   .ill
        CMP.W   #$014,D0
        BEQ.S   .zdiv
        CMP.W   #$060,D0
        BEQ.S   .spur
        CMP.W   #$064,D0
        BEQ.S   .ipl1
        CMP.W   #$068,D0
        BEQ.S   .ipl2
        CMP.W   #$070,D0
        BEQ.S   .ipl4
        CMP.W   #$078,D0
        BEQ.S   .ipl6
        RTS                         ; unknown vector - skip name
.bus    LEA     STR_VN_BUS,A0
        BRA.S   .pn
.addr   LEA     STR_VN_ADDR,A0
        BRA.S   .pn
.ill    LEA     STR_VN_ILL,A0
        BRA.S   .pn
.zdiv   LEA     STR_VN_ZDIV,A0
        BRA.S   .pn
.spur   LEA     STR_VN_SPUR,A0
        BRA.S   .pn
.ipl1   LEA     STR_VN_IPL1,A0
        BRA.S   .pn
.ipl2   LEA     STR_VN_IPL2,A0
        BRA.S   .pn
.ipl4   LEA     STR_VN_IPL4,A0
        BRA.S   .pn
.ipl6   LEA     STR_VN_IPL6,A0
.pn     BSR     PRINTSTR_SERIAL
        RTS


; FLUSH_TX -- wait for Z85C30 TX shift register to finish transmitting
; Polls RR0 bit 2 (TX buffer empty) then RR1 bit 0 (All Sent).
; Prevents garbled last char when SCC is reset immediately after print.
FLUSH_TX:
.txe    BTST    #2,SCC_A_CTRL       ; RR0 bit 2 = TX buffer empty
        BEQ.S   .txe
        MOVE.B  #1,SCC_A_CTRL       ; select RR1
.snt    BTST    #0,SCC_A_CTRL       ; RR1 bit 0 = All Sent (shift reg empty)
        BEQ.S   .snt
        MOVE.B  #0,SCC_A_CTRL       ; reset register select back to RR0
        RTS


;******************************************************************************
;  Z85C30 HAL
;******************************************************************************

; INIT_HW - initialise Ch A for 9600 8N1
INIT_HW:
        TST.B   $07000020           ; PAL sync strobe -- required before every SCC init (matches original ROM at 0x994 and 0x848B6)
        MOVE.B  #9,SCC_A_CTRL       ; select WR9
        MOVE.B  #$C0,SCC_A_CTRL     ; hardware reset (both channels)
        MOVE.L  #$2800,D0           ; delay for reset completion
.dly    SUBQ.L  #1,D0
        BNE.S   .dly
        ; WR4: x16 clock, 1 stop bit, no parity
        MOVE.B  #4,SCC_A_CTRL
        MOVE.B  #$44,SCC_A_CTRL
        ; WR11: BRG to Rx and Tx clocks
        MOVE.B  #11,SCC_A_CTRL
        MOVE.B  #$50,SCC_A_CTRL
        ; WR12/13: time constant for 9600 baud (matches original ROM values)
        MOVE.B  #12,SCC_A_CTRL
        MOVE.B  #$0A,SCC_A_CTRL
        MOVE.B  #13,SCC_A_CTRL
        MOVE.B  #$00,SCC_A_CTRL
        ; WR14: enable BRG, PCLK source
        MOVE.B  #14,SCC_A_CTRL
        MOVE.B  #$01,SCC_A_CTRL
        ; WR3: 8 bits/char, Rx enable
        MOVE.B  #3,SCC_A_CTRL
        MOVE.B  #$C1,SCC_A_CTRL
        ; WR5: 8 bits/char, Tx enable, /DTR asserted, RTS bit=0
        ; /RTSA feeds U18 LS30 (8-input NAND, other inputs tied high = acts as inverter).
        ; NAND output drives the RS-232 CTS pin via the line driver, so the polarity is
        ; inverted: RTS bit=0 -> /RTSA HIGH -> NAND LOW -> positive RS-232 -> CTS asserted.
        ; RTS bit=1 would deassert CTS and prevent the terminal from sending.
        MOVE.B  #5,SCC_A_CTRL
        MOVE.B  #$E8,SCC_A_CTRL     ; $E8=11101000: DTR+8bit+TxEnable, RTS=0 (CTS asserted)
        ; WR1: no interrupts
        MOVE.B  #1,SCC_A_CTRL
        MOVE.B  #$00,SCC_A_CTRL
        RTS


; PUTCHAR - output D0.B to serial or VERA depending on NV_CONSOLE_OUT bit 0
PUTCHAR:
        MOVEM.L D1,-(SP)            ; save D1 - GETLINE/PRINT_HEX depend on it
        BTST    #0,CONFIG_BUF+NV_CONSOLE_OUT
        BEQ.S   .pc_serial
        MOVE.W  VT_MAGIC,D1
        CMPI.W  #VT_MAGIC_VAL,D1
        BNE.S   .pc_serial
        ; VERA path: call VERA_PUTCHAR via JMP thunk (handles IPL blocking internally)
        MOVEM.L (SP)+,D1
        JSR     VT_VEC_PUTCHAR
        ; Tell the ISR to redraw the cursor at the new position on the
        ; next VSYNC frame.  Only touches RAM - no VERA registers, no
        ; register clobber.  The ISR checks VT_CURSOR_DIRTY and if set,
        ; forces cursor on and resets the blink timer.
        ; (Full CURSOR_ON call was removed: it caused BASIC screen corruption
        ; due to VERA ADDR0 contention with the VSYNC ISR between characters.)
        MOVE.B  #$FF,VT_CURSOR_DIRTY
        RTS
.pc_serial:
        MOVEM.L (SP)+,D1
PUTCHAR_SERIAL:
        BTST    #2,SCC_A_CTRL
        BEQ.S   PUTCHAR_SERIAL
        MOVE.B  D0,SCC_A_DATA
        RTS


; GETCHAR - input D0.B (blocking); PS/2 redirect reserved for future use
GETCHAR:
        BTST    #0,SCC_A_CTRL       ; RR0 bit 0 = Rx char available?
        BEQ.S   GETCHAR
        MOVE.B  SCC_A_DATA,D0
        RTS


; PRINTSTR - print NUL-terminated string at A0 to serial or VERA
PRINTSTR:
        MOVEM.L D0,-(SP)
        BTST    #0,CONFIG_BUF+NV_CONSOLE_OUT
        BEQ.S   .pss_serial
        MOVE.W  VT_MAGIC,D0
        CMPI.W  #VT_MAGIC_VAL,D0
        BNE.S   .pss_serial         ; fall back to serial if not initialized
        MOVEM.L (SP)+,D0
        JSR     VT_VEC_PRINTSTR     ; JMP thunk -> VERA_PRINTSTR in RAM
        RTS
.pss_serial:
        MOVE.B  (A0)+,D0
        BEQ.S   .pss_done
.pss_tx:
        BTST    #2,SCC_A_CTRL
        BEQ.S   .pss_tx             ; wait for Tx buffer empty
        MOVE.B  D0,SCC_A_DATA
        BRA.S   .pss_serial
.pss_done:
        MOVEM.L (SP)+,D0
        RTS


; PRINT_CRLF
PRINT_CRLF:
        MOVEM.L D0,-(SP)
        MOVE.B  #$0D,D0
        BSR     PUTCHAR
        MOVE.B  #$0A,D0
        BSR     PUTCHAR
        MOVEM.L (SP)+,D0
        RTS


; GETLINE - read line from serial into buffer at A0
; Handles BS ($08) / DEL ($7F) with destructive backspace.
; Returns A0 unchanged (pointing to buffer base).
GETLINE:
        MOVEM.L D0-D1/A1,-(SP)
        MOVEA.L A0,A1               ; A1 = write pointer
        MOVEQ   #LINE_BUF_SZ-1,D1  ; D1 = space remaining
.gl     BSR     GETCHAR
        CMP.B   #$0D,D0
        BEQ.S   .gldone
        CMP.B   #$0A,D0
        BEQ.S   .gldone
        CMP.B   #$08,D0
        BEQ.S   .glbs
        CMP.B   #$7F,D0
        BEQ.S   .glbs
        TST.L   D1
        BEQ.S   .gl
        MOVE.B  D0,(A1)+
        BSR     PUTCHAR
        SUBQ.L  #1,D1
        BRA.S   .gl
.glbs   CMP.L   #LINE_BUF_SZ-1,D1
        BEQ.S   .gl
        SUBQ.L  #1,A1
        ADDQ.L  #1,D1
        MOVE.B  #$08,D0
        BSR     PUTCHAR
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVE.B  #$08,D0
        BSR     PUTCHAR
        BRA.S   .gl
.gldone CLR.B   (A1)
        BSR     PRINT_CRLF
        MOVEM.L (SP)+,D0-D1/A1
        RTS


;******************************************************************************
;  Hex output utilities
;******************************************************************************

; PRINT_HEX8 - print D0.l as 8 hex digits
PRINT_HEX8:
        MOVEM.L D1-D2,-(SP)
        MOVE.L  D0,D1
        MOVEQ   #7,D2
.h8     ROL.L   #4,D1
        MOVE.B  D1,D0
        ANDI.B  #$0F,D0
        BSR     HEX_NYBBLE
        DBF     D2,.h8
        MOVEM.L (SP)+,D1-D2
        RTS

; PRINT_HEX4 - print D0.w as 4 hex digits
PRINT_HEX4:
        MOVEM.L D1-D2,-(SP)
        MOVE.W  D0,D1
        MOVEQ   #3,D2
.h4     ROL.W   #4,D1
        MOVE.B  D1,D0
        ANDI.B  #$0F,D0
        BSR     HEX_NYBBLE
        DBF     D2,.h4
        MOVEM.L (SP)+,D1-D2
        RTS

; PRINT_HEX2 - print D0.b as 2 hex digits
PRINT_HEX2:
        MOVEM.L D1,-(SP)
        MOVE.B  D0,D1
        LSR.B   #4,D0
        BSR     HEX_NYBBLE
        MOVE.B  D1,D0
        ANDI.B  #$0F,D0
        BSR     HEX_NYBBLE
        MOVEM.L (SP)+,D1
        RTS

; HEX_NYBBLE - output low nybble of D0 as ASCII
HEX_NYBBLE:
        ANDI.B  #$0F,D0
        ADDI.B  #'0',D0
        CMPI.B  #'9',D0
        BLE.S   .ok
        ADDI.B  #7,D0
.ok     BSR     PUTCHAR
        RTS


;******************************************************************************
;  Parse utilities  (A1 = parse cursor, updated in place)
;******************************************************************************

SKIP_SPACES_A1:
        CMP.B   #' ',(A1)
        BNE.S   .ss
        ADDQ.L  #1,A1
        BRA.S   SKIP_SPACES_A1
.ss     RTS

PARSE_HEX_A1:
        MOVEM.L D1,-(SP)
        MOVEQ   #0,D0
.ph     MOVE.B  (A1),D1
        CMP.B   #'a',D1
        BLT.S   .phnc
        CMP.B   #'f',D1
        BGT.S   .phnc
        SUBI.B  #$20,D1             ; fold lower to upper
.phnc   CMP.B   #'0',D1
        BLT.S   .phd
        CMP.B   #'9',D1
        BLE.S   .phdig
        CMP.B   #'A',D1
        BLT.S   .phd
        CMP.B   #'F',D1
        BGT.S   .phd
        SUBI.B  #7,D1               ; 'A'-'0'-7 = value 10
.phdig  SUBI.B  #'0',D1
        LSL.L   #4,D0
        OR.B    D1,D0
        ADDQ.L  #1,A1
        BRA.S   .ph
.phd    MOVEM.L (SP)+,D1
        RTS


;******************************************************************************
;  CMD_VERA_CFG - V: NVRAM configuration editor
;******************************************************************************
CMD_VERA_CFG:
        BSR     NVRAM_CONFIG
        BRA     CMD_LOOP


;******************************************************************************
;  CMD_TEST - T: continuous burn-in (code lives in extended section at $5000)
;******************************************************************************
CMD_TEST:
        BSR     BURNIN_TEST
        BRA     CMD_LOOP


;******************************************************************************
;  CMD_CPM - C: boot CP/M at $20000 (Bank 1)
;******************************************************************************
CMD_CPM:
        MOVEA.L #$00020000,A0
        MOVEM.L SAVE_D0,D0-D7
        MOVEM.L SAVE_A0+4,A1-A6
        JSR     (A0)
        MOVEM.L D0-D7,SAVE_D0
        MOVEM.L A0-A6,SAVE_A0
        MOVEA.L #STACK_TOP,SP
        LEA     STR_RETURNED,A0
        BSR     PRINTSTR
        BRA     CMD_REGS_SHOW


;******************************************************************************
;  CMD_UNIX - U: boot Unix at $40000 (Bank 2)
;******************************************************************************
CMD_UNIX:
        MOVEA.L #$00040000,A0
        MOVEM.L SAVE_D0,D0-D7
        MOVEM.L SAVE_A0+4,A1-A6
        JSR     (A0)
        MOVEM.L D0-D7,SAVE_D0
        MOVEM.L A0-A6,SAVE_A0
        MOVEA.L #STACK_TOP,SP
        LEA     STR_RETURNED,A0
        BSR     PRINTSTR
        BRA     CMD_REGS_SHOW


;******************************************************************************
;  CMD_SCSI - S: scan SCSI bus (code lives in extended section at $5000)
;******************************************************************************
CMD_SCSI:
        ORI.W   #$0700,SR              ; mask all interrupts during SCSI scan
        BSR     NS_SCSI_SCAN
        ANDI.W  #$F8FF,SR              ; restore interrupts
        BRA     CMD_LOOP


;******************************************************************************
;  RAM_TEST_BOOT - quick AA/55 RAM test
;
;  Writes $AAAAAAAA then $55555555 across RAM_TEST_START..RAM_TEST_END-4,
;  verifying read-back after each full write pass.
;
;  On error prints: address, expected, actual, XOR diff, bank# (0-3),
;  and the name of each failing D-line (D0..D31).
;  Suppresses further errors once RAM_MAX_ERRS per pattern is reached.
;
;  Called from START at boot and from CMD_TEST on demand.
;  Preserves all registers via MOVEM save/restore.
;******************************************************************************
RAM_TEST_BOOT:
        MOVEM.L D0-D7/A0-A3,-(SP)
        CLR.L   D7                       ; D7 = total error count across both patterns

        LEA     STR_RT_HDR,A0
        BSR     PRINTSTR

        MOVE.L  #$AAAAAAAA,D5
        BSR     RT_PASS
        MOVE.L  #$55555555,D5
        BSR     RT_PASS

        TST.L   D7
        BNE.S   .fail
        LEA     STR_RT_OK,A0
        BSR     PRINTSTR
        BRA.S   .rtdone
.fail   LEA     STR_RT_WARN,A0
        BSR     PRINTSTR
.rtdone MOVEM.L (SP)+,D0-D7/A0-A3
        RTS


;------------------------------------------------------------------------------
; RT_PASS - one write-then-verify pass with the pattern in D5
; D5 = pattern (preserved)
; D7 = running total error count (updated, not saved here)
; Trashes D0-D4/D6/A0-A3
;------------------------------------------------------------------------------
RT_PASS:
        MOVEQ   #0,D6                    ; D6 = per-pattern error count

        ; --- write pass ---
        MOVEA.L #RAM_TEST_START,A0
        MOVEA.L #RAM_TEST_END,A1
.wrt    MOVE.L  D5,(A0)+
        CMPA.L  A1,A0
        BLT.S   .wrt

        ; --- verify pass (one dot per 512KB block) ---
        MOVEA.L #RAM_TEST_START,A0
        MOVEA.L #RAM_TEST_START+$80000,A3
.vfy    CMPA.L  A3,A0
        BLT.S   .vchk
        ADDA.L  #$80000,A3
        MOVE.B  #'.',D0
        BSR     PUTCHAR
.vchk   MOVE.L  (A0)+,D4
        CMP.L   D5,D4
        BEQ.S   .ok
        MOVEA.L A0,A2
        SUBA.L  #4,A2                    ; A2 = address of failing longword
        BSR     RT_ERR
        ADDQ.L  #1,D6
        ADDQ.L  #1,D7
        CMP.L   #RAM_MAX_ERRS,D6
        BGE.S   .cap
.ok     CMPA.L  A1,A0
        BLT.S   .vfy
        RTS
.cap    LEA     STR_RT_CAP,A0
        BSR     PRINTSTR
        RTS


;------------------------------------------------------------------------------
; RT_ERR - print one error line
; A2 = failing address  D5 = expected value  D4 = actual value read
; Preserves D4/D5/D6/D7/A0/A1/A2 (the caller's working state)
;------------------------------------------------------------------------------
RT_ERR:
        MOVEM.L D0-D3/A0,-(SP)
        BSR     PRINT_CRLF

        ; address
        LEA     STR_RT_FAILAT,A0
        BSR     PRINTSTR
        MOVE.L  A2,D0
        BSR     PRINT_HEX8

        ; expected (written)
        LEA     STR_RT_WR,A0
        BSR     PRINTSTR
        MOVE.L  D5,D0
        BSR     PRINT_HEX8

        ; actual (read back)
        LEA     STR_RT_RD,A0
        BSR     PRINTSTR
        MOVE.L  D4,D0
        BSR     PRINT_HEX8

        ; diff = bits that are wrong
        MOVE.L  D5,D3
        EOR.L   D4,D3
        LEA     STR_RT_DIFF,A0
        BSR     PRINTSTR
        MOVE.L  D3,D0
        BSR     PRINT_HEX8

        ; bank number: (addr - $02000000) >> 20, low 2 bits
        MOVE.L  A2,D0
        SUBI.L  #$02000000,D0
        LSR.L   #8,D0
        LSR.L   #8,D0                    ; >> 16
        LSR.L   #4,D0                    ; >> 20
        ANDI.B  #$03,D0
        MOVE.B  D0,D2                    ; save bank digit
        LEA     STR_RT_BNK,A0
        BSR     PRINTSTR
        MOVE.B  D2,D0
        ADD.B   #'0',D0
        BSR     PUTCHAR

        ; failing D-lines: scan bits 0..31 of diff, print "D<n>" for each set bit
        MOVE.L  D3,D2                    ; D2 = diff (D3 preserved for nothing, but keep clean)
        MOVEQ   #0,D1                    ; D1 = bit index 0..31
.rtbl   BTST    D1,D2
        BEQ.S   .rtnb                    ; bit clear - not this D-line
        MOVE.B  #' ',D0
        BSR     PUTCHAR
        MOVE.B  #'D',D0
        BSR     PUTCHAR
        MOVE.L  D1,D0
        BSR     RT_PRINT_DEC2
.rtnb   ADDQ.L  #1,D1
        CMP.L   #32,D1
        BLT.S   .rtbl

        MOVEM.L (SP)+,D0-D3/A0
        RTS


;------------------------------------------------------------------------------
; RT_PRINT_DEC2 - print D0.l (range 0-31) as 1 or 2 decimal digits
;------------------------------------------------------------------------------
RT_PRINT_DEC2:
        MOVEM.L D0-D1,-(SP)
        DIVU    #10,D0                   ; D0.w = quotient, D0 hi word = remainder
        TST.W   D0                       ; quotient zero? (value was 0-9)
        BEQ.S   .rt2ones
        MOVE.W  D0,D1                    ; tens digit
        ADD.B   #'0',D1
        MOVE.B  D1,D0
        BSR     PUTCHAR
.rt2ones
        SWAP    D0                       ; remainder to low word
        ADD.B   #'0',D0
        BSR     PUTCHAR
        MOVEM.L (SP)+,D0-D1
        RTS


